  "compat": {
    "debian": {
      "security_official": "security.debian.org",
      "source_file": "/etc/apt/sources.list",
      "backup_path": "~/.config/tmoe-linux/sources.list.bak"
    },
    "ubuntu": {
      "source_file": "/etc/apt/sources.list",
      "security_official": null,
      "arm_path": "/ubuntu-ports",
      "backup_path": "~/.config/tmoe-linux/sources.list.bak"
    },
    "kali": {
      "source_file": "/etc/apt/sources.list",
      "rolling_branch": "kali-rolling",
      "backup_path": "~/.config/tmoe-linux/sources.list.bak"
    },
    "arch": {
      "source_file": "/etc/pacman.d/mirrorlist",
      "source_conf": "/etc/pacman.conf",
      "arm_repo": "archlinuxarm",
      "x86_repo": "archlinux",
      "backup_path": "~/.config/tmoe-linux/pacman.d_mirrorlist.bak",
      "backup_conf": "~/.config/tmoe-linux/pacman.conf.bak"
    },
    "manjaro": {
      "source_file": "/etc/pacman.d/mirrorlist",
      "arm_repo": "manjaro/arm-stable",
      "x86_repo": "manjaro/stable"
    },
    "alpine": {
      "source_file": "/etc/apk/repositories",
      "backup_path": "~/.config/tmoe-linux/alpine_repositories.bak",
      "repos": ["main", "community"]
    },
    "redhat": {
      "source_dir": "/etc/yum.repos.d",
      "backup_path": "~/.config/tmoe-linux/yum.repos.d-backup.tar.gz",
      "epel": "EPEL",
      "rpmfusion": "rpmfusion"
    }
  }
}
